<Window x:Class="VerticalPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vertical Player Pro"
        Height="860" Width="460"
        MinHeight="400" MinWidth="320"
        Background="#080C14"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ========== カラートークン ========== -->
        <SolidColorBrush x:Key="BgDeep"       Color="#080C14"/>
        <SolidColorBrush x:Key="BgSurface"    Color="#0F1623"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#141C2E"/>
        <SolidColorBrush x:Key="BgCard"       Color="#1A2438"/>
        <SolidColorBrush x:Key="BgHover"      Color="#1E2B42"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentCyan"   Color="#06B6D4"/>
        <SolidColorBrush x:Key="AccentViolet" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#64748B"/>
        <SolidColorBrush x:Key="TextFaint"    Color="#334155"/>
        <SolidColorBrush x:Key="Border"       Color="#1E2D45"/>

        <!-- ========== アイコンボタン ========== -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2B42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#263347"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== プライマリボタン ========== -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Padding="10,6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="#6366F1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== セカンダリボタン ========== -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#1A2438" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="10,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2B42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== 危険ボタン ========== -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#3B1A1A"/>
        </Style>

        <!-- ========== スライダー共通 ========== -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                                            <GradientStop Color="#6366F1" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#1E2D45" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="14" Height="14" Fill="White">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#3B82F6" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== スクロールバー非表示 ========== -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent" CornerRadius="2">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#334155" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== RadioButton ========== -->
        <Style x:Key="ModernRadio" TargetType="RadioButton">
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#1A2438" BorderBrush="{StaticResource Border}"
                                BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,2">
                            <DockPanel>
                                <Ellipse x:Name="Dot" Width="14" Height="14" DockPanel.Dock="Left" Margin="0,0,8,0"
                                         Stroke="#334155" StrokeThickness="2" Fill="Transparent"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Fill" Value="#3B82F6"/>
                                <Setter TargetName="Dot" Property="Stroke" Value="#3B82F6"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Bd" Property="Background" Value="#0F1E38"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2B42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== CheckBox ========== -->
        <Style x:Key="ModernCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <DockPanel>
                            <Border x:Name="Box" Width="16" Height="16" DockPanel.Dock="Left" Margin="0,0,8,0"
                                    CornerRadius="4" BorderBrush="#334155" BorderThickness="1.5" Background="Transparent">
                                <TextBlock x:Name="Mark" Text="✓" Foreground="White" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#6366F1" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Box"  Property="BorderBrush" Value="Transparent"/>
                                <Setter TargetName="Mark" Property="Visibility"  Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== TabControl ========== -->
        <Style x:Key="PanelTab" TargetType="TabControl">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- タブヘッダー -->
                            <Border Grid.Row="0" Background="#0F1623" CornerRadius="10,10,0,0" Padding="4">
                                <TabPanel IsItemsHost="True" HorizontalAlignment="Stretch"/>
                            </Border>
                            <!-- コンテンツ -->
                            <Border Grid.Row="1" Background="#141C2E" CornerRadius="0,0,10,10" Padding="12">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelTabItem" TargetType="TabItem">
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" CornerRadius="7" Padding="10,6" Margin="2">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2438"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2B42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== TextBox ========== -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#0F1623"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== セパレーター ========== -->
        <Style x:Key="Separator" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#1E2D45"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </Window.Resources>

    <!-- ========== ウィンドウシェル ========== -->
    <Border Background="{StaticResource BgDeep}" CornerRadius="14"
            BorderBrush="#1E2D45" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <!-- タイトルバー -->
                <RowDefinition Height="*"/>
                <!-- ビデオエリア -->
                <RowDefinition Height="Auto"/>
                <!-- コントロール -->
            </Grid.RowDefinitions>

            <!-- ========== タイトルバー ========== -->
            <Border Grid.Row="0" Background="#0A1020" CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：メニューボタン + タイトル -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MenuButton" Style="{StaticResource IconBtn}"
                                Click="Menu_Click" ToolTip="設定">
                            <Grid Width="16" Height="16">
                                <Path Data="M0,3 H16 M0,8 H16 M0,13 H16"
                                      Stroke="{StaticResource TextPrimary}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                        <!-- ロゴドット -->
                        <Ellipse Width="6" Height="6" Margin="4,0">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="VP" Foreground="{StaticResource TextPrimary}"
                                   FontSize="12" FontWeight="Bold" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                    </StackPanel>

                    <!-- 中央：ファイル名 -->
                    <TextBlock x:Name="FileNameText" Grid.Column="1"
                               Foreground="{StaticResource TextMuted}" FontSize="11"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="200"/>

                    <!-- 右：ウィンドウ操作 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconBtn}" Click="Minimize_Click" ToolTip="最小化" Padding="8">
                            <Path Data="M0,5 H10" Stroke="{StaticResource TextMuted}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}" Click="MaxRestore_Click" ToolTip="最大化/元に戻す" Padding="8">
                            <Path Data="M0,0 H10 V10 H0 Z" Stroke="{StaticResource TextMuted}"
                                  StrokeThickness="1.5" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}" Click="Close_Click" ToolTip="閉じる" Padding="8">
                            <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="#F87171"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== ビデオエリア ========== -->
            <Border Grid.Row="1" Background="Black" ClipToBounds="True">
                <Grid x:Name="VideoArea"
                      MouseWheel="Player_MouseWheel"
                      AllowDrop="True"
                      Drop="Window_Drop"
                      DragOver="Window_DragOver">

                    <!-- ドロップヒント -->
                    <Border x:Name="DropHint" Background="Transparent" CornerRadius="0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="72" Height="72" CornerRadius="20" Margin="0,0,0,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0F1E38" Offset="0"/>
                                        <GradientStop Color="#1A1040" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="M36,20 L36,44 M24,36 L36,48 L48,36 M20,52 H52"
                                      Stroke="#3B82F6" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="動画ファイルをドロップ" Foreground="{StaticResource TextMuted}"
                                       FontSize="13" HorizontalAlignment="Center"/>
                            <TextBlock Text="mp4 · mov · avi · mkv" Foreground="{StaticResource TextFaint}"
                                       FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ドラッグオーバー時のグロー枠 -->
                    <Border x:Name="DragGlow" Visibility="Collapsed"
                            BorderBrush="#3B82F6" BorderThickness="2" CornerRadius="0"
                            Background="#0A1828" Opacity="0.6"/>

                    <!-- MediaElement -->
                    <Viewbox Stretch="Uniform">
                        <MediaElement x:Name="Player"
                                      LoadedBehavior="Manual"
                                      RenderOptions.BitmapScalingMode="HighQuality"
                                      SnapsToDevicePixels="True"
                                      MediaOpened="Player_MediaOpened"
                                      MediaEnded="Player_MediaEnded"
                                      MediaFailed="Player_MediaFailed">
                            <MediaElement.LayoutTransform>
                                <TransformGroup>
                                    <RotateTransform x:Name="PlayerRotation"/>
                                    <ScaleTransform  x:Name="PlayerScale" ScaleX="1" ScaleY="1"/>
                                </TransformGroup>
                            </MediaElement.LayoutTransform>
                        </MediaElement>
                    </Viewbox>
                </Grid>
            </Border>

            <!-- ========== コントロールパネル ========== -->
            <Border Grid.Row="2" Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                <StackPanel Margin="16,12,16,14">

                    <!-- シークバー + 時間 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SeekBar" Grid.Column="0" Style="{StaticResource ModernSlider}"
                                Minimum="0" VerticalAlignment="Center"
                                Thumb.DragStarted="SeekBar_DragStarted"
                                Thumb.DragCompleted="SeekBar_DragCompleted"
                                PreviewMouseLeftButtonUp="SeekBar_PreviewMouseLeftButtonUp"/>
                        <TextBlock x:Name="TimeDisplay" Grid.Column="1"
                                   Foreground="{StaticResource TextMuted}" Text="0:00 / 0:00"
                                   FontSize="10" FontFamily="Consolas" Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- メインコントロール行 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左：音量 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="MuteButton" Style="{StaticResource IconBtn}"
                                    Click="Mute_Click" Padding="6" ToolTip="ミュート">
                                <Path x:Name="VolumeIcon"
                                      Data="M4,7 H8 L13,3 V17 L8,13 H4 Z M15,7 Q18,10 15,13 M17,5 Q22,10 17,15"
                                      Stroke="{StaticResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="20" Height="20"/>
                            </Button>
                            <Slider x:Name="VolumeSlider" Style="{StaticResource ModernSlider}"
                                    Width="80" Minimum="0" Maximum="1" Value="0.7"
                                    VerticalAlignment="Center" Margin="4,0,0,0"
                                    ValueChanged="Volume_Changed"/>
                        </StackPanel>

                        <!-- 中央：再生コントロール -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Style="{StaticResource IconBtn}" Click="Rotate_Click"
                                    ToolTip="90°回転" Padding="8">
                                <Path Data="M12,2 A10,10 0 0 1 22,12 M17,7 L22,2 L22,7"
                                      Stroke="{StaticResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource IconBtn}" Click="Rewind_Click"
                                    ToolTip="-10秒" Padding="8">
                                <Path Data="M14,6 L6,12 L14,18 Z M8,6 L8,18"
                                      Stroke="{StaticResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18"/>
                            </Button>

                            <!-- 再生/一時停止 (大) -->
                            <Button x:Name="PlayPauseButton" Click="PlayPause_Click"
                                    ToolTip="再生/一時停止" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Width="44" Height="44" CornerRadius="22">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                                    <GradientStop Color="#6366F1" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <!-- Play icon -->
                                <Path x:Name="PlayIcon"
                                      Data="M7,5 L19,12 L7,19 Z"
                                      Fill="White" Width="18" Height="18"
                                      Stretch="Uniform"/>
                            </Button>

                            <Button Style="{StaticResource IconBtn}" Click="FastForward_Click"
                                    ToolTip="+10秒" Padding="8">
                                <Path Data="M10,6 L18,12 L10,18 Z M16,6 L16,18"
                                      Stroke="{StaticResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource IconBtn}" Click="Stop_Click"
                                    ToolTip="停止" Padding="8">
                                <Rectangle Width="10" Height="10" Fill="{StaticResource TextMuted}" RadiusX="2" RadiusY="2"/>
                            </Button>
                        </StackPanel>

                        <!-- 右：追加機能 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource IconBtn}" Click="OpenFile_Click"
                                    ToolTip="ファイルを開く" Padding="8">
                                <Path Data="M2,4 H10 L12,6 H20 V18 H2 Z"
                                      Stroke="{StaticResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource IconBtn}" Click="ZoomReset_Click"
                                    ToolTip="ズームリセット" Padding="8">
                                <Path Data="M3,10 L10,3 L17,10 M10,3 V17 M3,20 H17"
                                      Stroke="{StaticResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- ループ / 状態インジケーター -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="LoopCheck" Grid.Column="0" Content="ループ"
                                  Style="{StaticResource ModernCheck}" FontSize="10"
                                  Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="StatusText" Grid.Column="2"
                                   Foreground="{StaticResource TextFaint}" FontSize="10"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ========== サイドパネル（スライドイン） ========== -->
            <Border x:Name="SidePanel" Grid.Row="0" Grid.RowSpan="3"
                    Background="#0D1525" Width="260"
                    HorizontalAlignment="Left" VerticalAlignment="Stretch"
                    Visibility="Collapsed" Panel.ZIndex="20"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="24" Direction="0" ShadowDepth="8" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- パネルヘッダー -->
                    <Border Grid.Row="0" Background="#080C14"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <DockPanel Margin="14,0">
                            <TextBlock Text="設定" Foreground="{StaticResource TextPrimary}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource IconBtn}"
                                    Click="Menu_Click" Padding="6" ToolTip="閉じる">
                                <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{StaticResource TextMuted}"
                                      StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="10" Height="10"/>
                            </Button>
                        </DockPanel>
                    </Border>

                    <!-- タブコンテンツ -->
                    <TabControl Grid.Row="1" Style="{StaticResource PanelTab}">
                        <TabItem Header="表示" Style="{StaticResource PanelTabItem}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <!-- 表示モード -->
                                    <TextBlock Text="表示モード" Foreground="{StaticResource TextMuted}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"
                                              />
                                    <RadioButton x:Name="NormalMode" GroupName="ViewMode"
                                                 Content="通常モード" Style="{StaticResource ModernRadio}"
                                                 IsChecked="True" Checked="Mode_Checked"/>
                                    <RadioButton x:Name="ForceVerticalMode" GroupName="ViewMode"
                                                 Content="強制縦型モード" Style="{StaticResource ModernRadio}"
                                                 Checked="Mode_Checked"/>

                                    <Border Style="{StaticResource Separator}"/>

                                    <!-- ハードウェア設定 -->
                                    <TextBlock Text="ハードウェア" Foreground="{StaticResource TextMuted}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"
                                              />
                                    <CheckBox x:Name="HwAccelCheck" Content="ハードウェアアクセラレーション"
                                              Style="{StaticResource ModernCheck}" Margin="0,4"/>
                                    <CheckBox x:Name="AlwaysOnTopCheck" Content="常に最前面"
                                              Style="{StaticResource ModernCheck}" Margin="0,4"
                                              Checked="AlwaysOnTop_Changed" Unchecked="AlwaysOnTop_Changed"/>

                                    <Border Style="{StaticResource Separator}"/>

                                    <!-- 再生速度 -->
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="再生速度" Foreground="{StaticResource TextMuted}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="SpeedLabel" DockPanel.Dock="Right"
                                                   Foreground="{StaticResource AccentBlue}"
                                                   FontSize="10" FontFamily="Consolas" Text="1.0×"/>
                                    </DockPanel>
                                    <Slider x:Name="SpeedSlider" Style="{StaticResource ModernSlider}"
                                            Minimum="0.25" Maximum="3.0" Value="1.0"
                                            IsSnapToTickEnabled="True" TickFrequency="0.25"
                                            ValueChanged="Speed_Changed" Margin="0,4"/>

                                    <Border Style="{StaticResource Separator}"/>
                                    <Button Content="ウィンドウを画面中央へ" Style="{StaticResource SecondaryBtn}"
                                            Click="CenterWindow_Click" Margin="0,4"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="エフェクト" Style="{StaticResource PanelTabItem}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <!-- スライダー群 -->
                                    <StackPanel x:Name="EffectSliders">
                                        <!-- コントラスト -->
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="コントラスト" Foreground="{StaticResource TextMuted}"
                                                       FontSize="10" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="ContrastLabel" DockPanel.Dock="Right"
                                                       Foreground="{StaticResource AccentCyan}"
                                                       FontSize="10" FontFamily="Consolas" Text="0.0"/>
                                        </DockPanel>
                                        <Slider x:Name="ContrastSlider" Style="{StaticResource ModernSlider}"
                                                Minimum="-1" Maximum="1" Value="0"
                                                IsSnapToTickEnabled="True" TickFrequency="0.1"
                                                ValueChanged="Effect_Changed" Margin="0,0,0,10"/>

                                        <!-- 彩度 -->
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="彩度" Foreground="{StaticResource TextMuted}"
                                                       FontSize="10" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="SaturationLabel" DockPanel.Dock="Right"
                                                       Foreground="{StaticResource AccentCyan}"
                                                       FontSize="10" FontFamily="Consolas" Text="0.0"/>
                                        </DockPanel>
                                        <Slider x:Name="SaturationSlider" Style="{StaticResource ModernSlider}"
                                                Minimum="-1" Maximum="1" Value="0"
                                                IsSnapToTickEnabled="True" TickFrequency="0.1"
                                                ValueChanged="Effect_Changed" Margin="0,0,0,10"/>

                                        <!-- ガンマ -->
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="ガンマ" Foreground="{StaticResource TextMuted}"
                                                       FontSize="10" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="GammaLabel" DockPanel.Dock="Right"
                                                       Foreground="{StaticResource AccentCyan}"
                                                       FontSize="10" FontFamily="Consolas" Text="0.0"/>
                                        </DockPanel>
                                        <Slider x:Name="GammaSlider" Style="{StaticResource ModernSlider}"
                                                Minimum="-1" Maximum="1" Value="0"
                                                IsSnapToTickEnabled="True" TickFrequency="0.1"
                                                ValueChanged="Effect_Changed" Margin="0,0,0,10"/>
                                    </StackPanel>

                                    <Button Content="エフェクトをリセット" Style="{StaticResource DangerBtn}"
                                            Click="ResetEffects_Click" Margin="0,4"/>

                                    <Border Style="{StaticResource Separator}"/>

                                    <!-- プリセット管理 -->
                                    <TextBlock Text="プリセット" Foreground="{StaticResource TextMuted}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"
                                              />

                                    <!-- プリセット名入力 -->
                                    <TextBox x:Name="PresetNameBox" Style="{StaticResource ModernTextBox}"
                                             Text="プリセット名" Margin="0,0,0,6"/>

                                    <Button Content="現在値をプリセット保存" Style="{StaticResource PrimaryBtn}"
                                            Click="SavePreset_Click" Margin="0,0,0,8"/>

                                    <!-- プリセット一覧 -->
                                    <ItemsControl x:Name="PresetList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A2438" CornerRadius="8"
                                                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                        Margin="0,3" Padding="8,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="11" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="1" Content="適用"
                                                                Style="{StaticResource PrimaryBtn}"
                                                                Padding="6,4" FontSize="10"
                                                                Tag="{Binding}"
                                                                Click="ApplyPreset_Click" Margin="4,0,0,0"/>
                                                        <Button Grid.Column="2" Content="✕"
                                                                Style="{StaticResource DangerBtn}"
                                                                Padding="6,4" FontSize="10"
                                                                Tag="{Binding}"
                                                                Click="DeletePreset_Click" Margin="4,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="情報" Style="{StaticResource PanelTabItem}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="InfoPanel">
                                    <TextBlock Text="動画情報" Foreground="{StaticResource TextMuted}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"
                                              />
                                    <StackPanel x:Name="VideoInfoStack"/>

                                    <Border Style="{StaticResource Separator}"/>

                                    <TextBlock Text="操作ガイド" Foreground="{StaticResource TextMuted}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"
                                              />
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10"
                                                   Text="🖱 ホイール — ズーム" Margin="0,3"/>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10"
                                                   Text="⌨ スペース — 再生/停止" Margin="0,3"/>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10"
                                                   Text="⌨ ← → — 10秒シーク" Margin="0,3"/>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10"
                                                   Text="⌨ ↑ ↓ — 音量調節" Margin="0,3"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <!-- サイドパネルオーバーレイ（クリックで閉じる） -->
            <Border x:Name="PanelOverlay" Grid.Row="0" Grid.RowSpan="3"
                    Background="Transparent" Visibility="Collapsed" Panel.ZIndex="19"
                    MouseLeftButtonDown="PanelOverlay_Click"/>
        </Grid>
    </Border>
</Window>
